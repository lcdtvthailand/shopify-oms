# Cloudflare Wrangler Local Development Variables
# Copy this to .dev.vars and fill in your values

# Required
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxx

# Optional
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourdomain.com
NEXT_PUBLIC_ADMIN_PHONE=02-xxx-xxxx
NEXT_PUBLIC_ADMIN_LINE_ID=@yourlineid
NEXT_PUBLIC_ADMIN_OFFICE_HOURS=Mon-Fri 9:00-18:00

# OMS Link Security
OMS_TOKEN_SECRET=your-secret-key-here
OMS_LINK_TTL_HOURS=72

# Order Report Security
ORDER_REPORT_PASSWORD=xxxxxxxxxx

# Gmail API (for sending tax invoice confirmation emails)
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_SENDER_EMAIL=shop@lcdtvthailand.com
GMAIL_ADMIN_EMAIL=shop@lcdtvthailand.com